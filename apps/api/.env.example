# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/trackai

# Supabase JWT Secret (found in Supabase Dashboard → Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# Frontend URL for CORS (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:3000

# Server port (Cloud Run uses 8080 by default)
PORT=8080
