# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/trackai

# Supabase JWT Secret (found in Supabase Dashboard → Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# Shared secret configured on the GitHub webhook
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret-here

# Task2 read-only GitHub App foundation. Prefer the app credentials in real use;
# the explicit installation token is a short-lived local test override only.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
# Preferred for multiple tenant organizations: normalized owner slug -> ID.
GITHUB_APP_INSTALLATIONS_JSON={"mahamannu-ai":"123","customer-b-corp-ai":"456"}
GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GITHUB_APP_INSTALLATION_TOKEN=
# Public unauthenticated reads are opt-in and intended only for local fixtures.
GITHUB_ALLOW_PUBLIC_READ=false

# Temporary Task1 machine credentials: opaque API key -> tenant UUID.
# Rotate out through Task4's production key lifecycle.
TRACKAI_INGEST_TOKENS_JSON={"replace-with-long-random-token":"00000000-0000-0000-0000-000000000000"}

# Frontend URL for CORS (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:3000

# Server port (Cloud Run uses 8080 by default)
PORT=8080
